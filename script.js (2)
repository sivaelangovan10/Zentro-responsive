// auto scroll div

const divs = document.getElementById("scrolldiv")

let pos = 0

function autoscroll() {
    pos += 1
    divs.scrollTop = pos

    if(pos >= divs.scrollHeight - divs.clientHeight) {
        pos = 0

    }

}

setInterval(autoscroll , 2)

